---
interface Props {
  name: string;
  class?: string;
  style?: string;
}

const { name, class: className, style } = Astro.props;

const files = import.meta.glob<string>("../icons/**/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});

const filepath = `../icons/${name}.svg`;
const svgContent = files[filepath];

let scopedSvg = svgContent;

if (svgContent.includes("<style")) {
  const uniqueClass = `icon-${name}`;

  scopedSvg = scopedSvg.replace("<svg", `<svg class="${uniqueClass}"`);

  scopedSvg = scopedSvg.replace(
    /<style[^>]*>([\s\S]*?)<\/style>/,
    (_match, css) => {
      return `<style>${css.replace(/(^|\n)\s*([^{]+){/g, `$1.${uniqueClass} $2{`)}</style>`;
    },
  );
}

if (!svgContent) {
  console.error(`[Icon] El icono "${name}" no se encontró en src/icons/`);
}
---

{
  svgContent ? (
    <span
      class={`inline-flex items-center justify-center ${className}`}
      style={style}
      set:html={scopedSvg}
    />
  ) : (
    <span class="text-red-500 text-xs">Icon not found</span>
  )
}

<style is:global>
  .inline-flex svg {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
  }
</style>
