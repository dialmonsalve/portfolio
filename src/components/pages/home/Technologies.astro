---
import Icon from "@Icon/Icon.astro";

import { TECHNOLOGIES } from "@/const/technologies";
---

<div class="p-1 rounded-lg xl.mt-20">
  <ul class="grid grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3 tech-list">
    {
      TECHNOLOGIES.map(({ icon, name }) => (
        <li class="flex flex-col items-center group relative p-2 border border-gray-500 cursor-pointer rounded-md shadow-2xl tech-item">
          <Icon
            name={icon}
            aria-label={name}
            class="group-hover:scale-125 transition-all w-10 h-10 block icon-wrapper"
          />
          <span class="absolute top-0 left-1 mt-1 hidden group-hover:block text-xs px-2 py-1 rounded transition-all">
            {name}
          </span>
          <span class="text-[8px] text-center block md:text-lg">{name}</span>
        </li>
      ))
    }
  </ul>
  <a
    class="mt-3 text-xs hover:underline block text-end"
    target="_blank"
    href="https://iconos8.es/icons"
  >
    Icons from: iconos8
  </a>

  <script src="@/lib/animations/technologies.ts">  </script>
</div>
