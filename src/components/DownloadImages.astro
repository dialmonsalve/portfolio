---
import { getI18N } from "@/i18n/index";
import Icon from "./Icon.astro";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
---

<article class="w-full md:w-4/5">
  <div class="mt-4">
    <dial-upload-drop-zone class="">
      <div
        class="flex flex-col items-center justify-center w-full gap-2 "
        id="parent-drop-zone"
      >
        <label
          for="file-download"
          class="flex flex-col items-center justify-center w-100 h-50 border-2 border-base-300 rounded-lg cursor-pointer border-dashed drop-zone hover:bg-base-300 hover:border-blue-500 transition-colors"
          id="drop-zone"
        >
          <div class="flex flex-col items-center justify-center pt-5 pb-6">
            <Icon name="upload" class="w-10 text-info" />
            <p class="mb-2 text-sm text-info">
              <span class="font-semibold">{i18n.projects.click} </span>
              {i18n.projects.drag}
            </p>
            <p class="text-xs text-info">WEBP, PNG, JPEG O JPG</p>
          </div>
          <input
            id="file-download"
            name="imageFiles"
            type="file"
            accept="image/png,image/jpeg,image/jpg,image/webp,image/avif"
            multiple
            class="hidden"
          />
        </label>
        <p class="my-2 text-sm text-error" id="lbl-selected-files">
          {i18n.projects.files}
        </p>
      </div>
    </dial-upload-drop-zone>
  </div>
</article>

<script src="@/lib/dial-drop-zone"></script>
