---
import { getLangFromUrl, useTranslatedPath } from "../i18n/utils.ts";

interface Props {
  title: string;
  image: string;
  description: string;
  slug: string;
  isExternalProject: boolean;
}
import { getI18N } from "../i18n";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const { title, image, description, slug, isExternalProject } = Astro.props;
---

<div
  class="h-[250px] flex flex-col gap-8 border border-primary p-4 rounded-sm shadow-primary shadow-md justify-between items-center bg-white dark:bg-gray-900"
>
  <div class="relative">
    <h6
      class="bg-yellow-300 rounded-sm text-gray-800 px-2 py-1 -translate-y-8"
      transition:name={slug}
    >
      {title}
    </h6>
  </div>

  <div class="card__body">
    <img class="card__body--image" src={image} alt={description} />
    <p class="text-gray-800 dark:text-white">{description}</p>
  </div>

  <div class="flex w-full justify-around">
    <button
      class="py-1 px-3 rounded-sm uppercase text-md text-white transition-colors cursor-pointer bg-blue-500 shadow-lg shadow-blue-500/50 hover:opacity-85"
      >{i18n.GENERAL.MORE}</button
    >
    {
      isExternalProject ? (
        <a
          target="_blank"
          referrerpolicy="no-referrer"
          href={slug}
          class="py-1 px-3 rounded-sm uppercase text-md text-white transition-colors cursor-pointer bg-indigo-500 shadow-lg shadow-indigo-500/50 hover:opacity-85"
        >
          {i18n.GENERAL.GO}
        </a>
      ) : (
        <a
          href={translatePath(`/projects/${slug}`)}
          class="py-1 px-3 rounded-sm uppercase text-md text-white transition-colors cursor-pointer bg-indigo-500 shadow-lg shadow-indigo-500/50 hover:opacity-85"
        >
          {i18n.GENERAL.GO}
        </a>
      )
    }
  </div>
</div>

<style>
  button:active,
  a:active {
    box-shadow: 2px 2px 8px #0f0f0fac inset;
  }
</style>
