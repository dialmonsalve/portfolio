---
interface Props {
  isNotFound?: boolean;
}

const { isNotFound = false } = Astro.props;

function createBreadcrumbs() {
  const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";
  const homeName = lang === "es" ? "inicio" : "home";
  
  const langPath = `/${lang}`;

  const cleanRoute = Astro.url.pathname
    .replace(new RegExp(`^\\/${lang}`), "")
    .replace(/^\/+|\/+$/g, "");

  if (cleanRoute === "") {
    return [{ name: homeName, href: langPath }];
  }

  const parts = cleanRoute.split("/");
  const breadcrumbs = parts.map((part, index) => {
    const currentPath = parts.slice(0, index + 1).join("/");
    
    const href = `${langPath}/${currentPath}`;

    return {
      name: part.replace(/-/g, " "),
      href: href,
    };
  });

  return [{ name: homeName, href: langPath }, ...breadcrumbs];
}

const breadcrumbs = createBreadcrumbs();
---

{
  !isNotFound && breadcrumbs.length > 0 && (
    <ul class="flex gap-1 pt-4 lg:pt-10 lg:pl-10">
      {breadcrumbs.map(({ href, name }) => (
        <li class="flex gap-1 items-center text-[12px]">
          {href !== Astro.url.pathname && href !== `${Astro.url.pathname}/` ? (
            <a
              class="block py-0.5 px-2 bg-green-700 rounded-r-xl text-white text-[12px] md:text-sm"
              href={href}
            >
              {name}
            </a>
          ) : (
            <span class="block py-0.5 px-2 bg-gray-400 rounded-r-xl text-gray-800  text-[12px] md:text-sm">
              {name}
            </span>
          )}
        </li>
      ))}
    </ul>
  )
}
