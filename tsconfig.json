{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["@astrojs/cloudflare"],
    "paths": {
      "@/*": ["./src/*"],
      "@Icon/*": ["./src/components/*"]
    }
  }
}
